{
  "name": "semantris-plus-frontend",
  "private": true,
  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "node scripts/build-frontend.mjs",
    "check:frontend": "tsc --noEmit",
    "lint": "biome check frontend/src e2e playwright.config.ts vitest.config.ts",
    "format:check": "biome format --check frontend/src e2e playwright.config.ts vitest.config.ts",
    "test:frontend": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.12",
    "jsdom": "^27.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
